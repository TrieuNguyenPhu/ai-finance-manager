# Copy to `.env` for local overrides. Never commit real secrets.
# Local Docker Compose reads this file via `make up` for defaults.

# --- Shared / AWS (not provisioned in foundation) ---
AWS_REGION=ap-southeast-1

# --- Local PostgreSQL (infra/docker-compose.yml) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=afm
POSTGRES_PASSWORD=afm_local_only
POSTGRES_DB=afm
DATABASE_URL=postgresql://afm:afm_local_only@localhost:5432/afm

# Read-only URL for optional tooling (MCP). Leave empty until needed.
READONLY_DATABASE_URL=

# --- Service ports ---
GATEWAY_ADDR=:8080
FINANCE_CORE_PORT=8081
AI_INSIGHT_PORT=8082
WEB_PORT=3000

# --- AI provider (unused until AI features land) ---
AI_PROVIDER=
AI_API_KEY=

# --- Optional Cursor MCP / GitHub tooling ---
GITHUB_PERSONAL_ACCESS_TOKEN=
