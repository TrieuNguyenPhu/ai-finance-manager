# Never put real secrets in this file. Local passwords are for Compose Postgres only.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# gateway-service upstreams
IDENTITY_BASE_URL=http://127.0.0.1:8080
TRANSACTION_BASE_URL=http://127.0.0.1:8081
BUDGET_BASE_URL=http://127.0.0.1:8082
ANALYTICS_BASE_URL=http://127.0.0.1:8083
AI_BASE_URL=http://127.0.0.1:8001
NOTIFICATION_BASE_URL=http://127.0.0.1:8084
REDIS_URL=redis://127.0.0.1:6379/0

# Local JWT stub (HS256). Replace when Cognito is wired.
AUTH_DEV_MODE=true
AUTH_JWT_SECRET=local-dev-only-change-me-32chars!!
AUTH_JWT_ISSUER=ai-finance-manager-local
COGNITO_ISSUER=

# Postgres (docker compose defaults)
POSTGRES_PORT=5432
POSTGRES_USER=afm
POSTGRES_PASSWORD=afm_local_only
POSTGRES_DB=afm
REDIS_PORT=6379
LOCALSTACK_PORT=4566
SQS_ENDPOINT_URL=http://127.0.0.1:4566

IDENTITY_DB_URL=jdbc:postgresql://127.0.0.1:5432/afm
IDENTITY_DB_USER=identity_app
IDENTITY_DB_PASSWORD=identity_local

TRANSACTION_DB_URL=jdbc:postgresql://127.0.0.1:5432/afm
TRANSACTION_DB_USER=transaction_app
TRANSACTION_DB_PASSWORD=transaction_local
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=3000
DB_MAX_LIFETIME_MS=1800000
DB_IDLE_TIMEOUT_MS=300000

BUDGET_DATABASE_URL=postgres://budget_app:budget_local@127.0.0.1:5432/afm?search_path=budget&sslmode=disable
ANALYTICS_DATABASE_URL=postgres://analytics_app:analytics_local@127.0.0.1:5432/afm?search_path=analytics&sslmode=disable
NOTIFICATION_DATABASE_URL=postgres://notification_app:notification_local@127.0.0.1:5432/afm?search_path=notification&sslmode=disable

# ai-service — keys server-side only. Put real keys in .env, never here.
# AI_PROVIDER=groq requires GROQ_API_KEY; anything else falls back to rules.
AI_PROVIDER=rules
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=

# Shared secret for service-to-service /internal/events delivery
# (transaction-service outbox -> budget/analytics/notification).
INTERNAL_EVENTS_TOKEN=local-internal-events-token

OUTBOX_RELAY_ENABLED=true
OUTBOX_TRANSPORT=http
SQS_ENABLED=false
SQS_VISIBILITY_TIMEOUT_SECONDS=60
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
BUDGET_QUEUE_URL=http://127.0.0.1:4566/000000000000/budget-events
ANALYTICS_QUEUE_URL=http://127.0.0.1:4566/000000000000/analytics-events
NOTIFICATION_QUEUE_URL=http://127.0.0.1:4566/000000000000/notification-events
